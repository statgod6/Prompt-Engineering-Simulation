# PromptLab Configuration
# Copy this to .env and fill in your values

# Required: OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database (default: SQLite, change to PostgreSQL for production)
DATABASE_URL=sqlite:////data/promptlab.db

# Security
SECRET_KEY=change-this-to-a-random-string-in-production

# Token Budget (daily limit per user)
DAILY_TOKEN_BUDGET=100000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
